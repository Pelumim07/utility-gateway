# Copy this file to .env and fill in your own values.
# NEVER commit your real .env file to GitHub.

# Private key of the wallet that will deploy the contract (needs testnet MON,
# get some free from https://faucet.monad.xyz).
# Do NOT include the 0x prefix issue here - hardhat expects it WITH 0x.
PRIVATE_KEY=0xc6d5ea20951028c086866997d155588780023fc58fcd7009418b02d0d124f37a

# Monad testnet RPC (official public endpoint, fine for hackathon use)
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz/

# Wallet address your backend listener will use to call markFulfilled/
# markFailed. For Day 1 this can be the SAME address as your deployer -
# you can rotate it to a dedicated backend wallet later.
OPERATOR_ADDRESS=0xaD090C3285f16741F077B50ef8F9Db8Fe3858B1B

CONTRACT_ADDRESS=0xDdDDDACabBbe4B9c412B4a6aF14007aE7FDbCcbC

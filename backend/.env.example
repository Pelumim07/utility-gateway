# Copy this file to .env and fill in your own values.
# NEVER commit your real .env file to GitHub.

# --- Monad ---
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz/
CONTRACT_ADDRESS=0xpaste_the_deployed_AirtimeGateway_address_here

# Private key of the OPERATOR wallet (the address you passed as
# OPERATOR_ADDRESS when deploying). This wallet calls markFulfilled /
# markFailed, so it needs a little testnet MON for gas.
OPERATOR_PRIVATE_KEY=0xyour_operator_private_key_here

# --- VTpass sandbox ---
# Get these from https://sandbox.vtpass.com/account -> API Keys tab
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
VTPASS_API_KEY=your_sandbox_api_key
VTPASS_SECRET_KEY=your_sandbox_secret_key

# Email VTpass requires on every purchase payload (sandbox accepts any valid-looking email)
VTPASS_EMAIL=you@example.com
